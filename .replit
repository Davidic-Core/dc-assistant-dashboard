modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
packages = ["git", "automaticcomponenttoolkit"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 3001

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 23125
externalPort = 3000
